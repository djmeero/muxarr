<table class="table table-sm mb-0">
    <thead>
    <tr>
        <th style="width: 35px;">#</th>
        <th>Language</th>
        <th>Format</th>
        <th>Details</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in KeptTracks)
    {
        <MediaTrackDetail Track="item.Original"
                          Preview="item.Preview"
                          OriginalLanguage="@OriginalLanguage"
                          MovedFromPosition="item.MovedFromPosition"/>
    }
    @foreach (var track in RemovedTracks)
    {
        <tr class="opacity-50">
            <td>@track.Index</td>
            <td>
                <MediaTrackLabel Track="track" ShowAllFlags="true"/>
            </td>
            <td><code>@track.Codec.FormatCodec()</code></td>
            <td><i class="bi bi-x-circle-fill text-danger"></i> will be removed</td>
        </tr>
    }
    @foreach (var preview in ExternalTracks)
    {
        <tr>
            <td>@preview.Index</td>
            <td>
                <MediaTrackLabel Track="preview" ShowAllFlags="true" IsExternal="true"/>
            </td>
            <td><code>@(((IMediaTrack)preview).Codec.FormatCodec())</code></td>
            <td><i class="bi bi-plus-circle-fill text-success"></i> will be muxed in from external file</td>
        </tr>
    }
    </tbody>
</table>

@code {
    [Parameter] [EditorRequired] public IEnumerable<IMediaTrack> Tracks { get; set; } = default!;
    [Parameter] public List<TrackPlan>? PreviewTracks { get; set; }
    [Parameter] [EditorRequired] public string? OriginalLanguage { get; set; }

    private record TrackWithPreview(IMediaTrack Original, TrackPlan? Preview, int? MovedFromPosition);

    private List<TrackWithPreview> KeptTracks { get; set; } = [];
    private List<IMediaTrack> RemovedTracks { get; set; } = [];
    private List<TrackPlan> ExternalTracks { get; set; } = [];

    protected override void OnParametersSet()
    {
        if (PreviewTracks == null || PreviewTracks.Count == 0)
        {
            KeptTracks = Tracks.Select(t => new TrackWithPreview(t, null, null)).ToList();
            RemovedTracks = [];
            ExternalTracks = [];
            return;
        }

        var previewByNumber = PreviewTracks.ToDictionary(p => p.Index);
        var originalPositions = Tracks.Select((t, i) => (TrackNumber: t.Index, Index: i))
            .ToDictionary(x => x.TrackNumber, x => x.Index);

        KeptTracks = [];
        for (var i = 0; i < PreviewTracks.Count; i++)
        {
            var preview = PreviewTracks[i];
            var original = Tracks.FirstOrDefault(t => t.Index == preview.Index);
            if (original == null)
            {
                continue;
            }

            int? movedFrom = null;
            if (originalPositions.TryGetValue(preview.Index, out var origIdx) && origIdx != i)
            {
                movedFrom = origIdx + 1;
            }

            KeptTracks.Add(new TrackWithPreview(original, preview, movedFrom));
        }

        RemovedTracks = Tracks.Where(t => !previewByNumber.ContainsKey(t.Index)).ToList();
        ExternalTracks = PreviewTracks.Where(p => p.SourcePath != null && Tracks.All(t => t.Index != p.Index)).ToList();
    }

}
