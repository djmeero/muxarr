<span class="me-1 badge @GetTrackTypeBadgeClass(Track.Type)">
    <i class="bi @GetTrackTypeIcon(Track.Type) me-1"></i>@(Track.Type == MediaTrackType.Video ? "Video" : Track.LanguageName)
    @if (Track.GetChannelLayout() is { } channels)
    {
        <span class="opacity-75 ms-1">@channels</span>
    }
    @if (Track.IsHearingImpaired)
    {
        <ToolTip Tip="Hearing Impaired (SDH)"><i class="bi bi-ear ms-1"></i></ToolTip>
    }
    @if (Track.IsCommentary)
    {
        <ToolTip Tip="Commentary"><i class="bi bi-chat-quote ms-1"></i></ToolTip>
    }
    @if (Track.IsForced)
    {
        <ToolTip Tip="Forced - shows even when subtitles are off"><i class="bi bi-lock ms-1"></i></ToolTip>
    }
    @if (Track.IsDub)
    {
        <ToolTip Tip="Dubbed - translated audio (e.g. English dub of a Japanese show)"><i
                class="bi bi-translate ms-1"></i></ToolTip>
    }
    @if (ShowAllFlags)
    {
        @if (Track.IsOriginal)
        {
            <ToolTip Tip="Original language track"><i class="bi bi-check-circle ms-1"></i></ToolTip>
        }

        @if (Track.IsVisualImpaired)
        {
            <ToolTip Tip="Visual Impaired (Audio Description)"><i class="bi bi-eye ms-1"></i></ToolTip>
        }

        @if (Track.IsDefault)
        {
            <ToolTip Tip="Default - player will auto-select this track"><i class="bi bi-play-circle ms-1"></i></ToolTip>
        }
    }
    @if (IsExternal)
    {
        <span class="badge bg-info ms-1" title="Will be muxed in from an external file">external</span>
    }
</span>

@code {
    [Parameter] [EditorRequired] public required IMediaTrack Track { get; set; }

    [Parameter] public bool ShowAllFlags { get; set; }

    [Parameter] public bool IsExternal { get; set; }

    private static string GetTrackTypeIcon(MediaTrackType trackType)
    {
        return trackType switch
        {
            MediaTrackType.Video => "bi-film",
            MediaTrackType.Audio => "bi-volume-up",
            MediaTrackType.Subtitles => "bi-chat-text",
            _ => "bi-question-circle"
        };
    }

    private static string GetTrackTypeBadgeClass(MediaTrackType trackType)
    {
        return trackType switch
        {
            MediaTrackType.Video => "bg-success text-white",
            MediaTrackType.Audio => "bg-primary text-white",
            MediaTrackType.Subtitles => "bg-warning text-dark",
            _ => "bg-secondary text-white"
        };
    }

}
