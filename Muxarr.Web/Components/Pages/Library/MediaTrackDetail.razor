<tr>
    <td>
        @if (IsReordered)
        {
            <ToolTip Tip="@($"Moved from position {MovedFromPosition}")">
                <span class="badge bg-primary-subtle text-primary-emphasis">
                    <i class="bi bi-arrow-down-up"></i>
                </span>
            </ToolTip>
        }
        else
        {
            @Track.Index
        }
    </td>
    <td>
        <MediaTrackLabel Track="Track" ShowAllFlags="true" IsExternal="@(Preview?.SourcePath != null)"/>
        @if (ResolvedLanguage != null)
        {
            <i class="bi bi-arrow-right text-info mx-1" style="font-size: 0.7rem;"></i>
            <span class="badge bg-info text-white">@ResolvedLanguage</span>
        }
        @if (DisplayLanguage == OriginalLanguage)
        {
            <ToolTip
                Tip="@(ResolvedLanguage != null ? $"Undetermined -> {ResolvedLanguage} (original language)" : "Original Language")">
                <i class="bi bi-star-fill text-warning ms-1" style="font-size: 0.65rem;"></i>
            </ToolTip>
        }
    </td>
    <td><code>@Track.Codec.FormatCodec()</code></td>
    <td>
        @* Track name changes *@
        @if (HasTrackNameChange)
        {
            @if (!string.IsNullOrEmpty(Track.Name))
            {
                <span class="text-muted small text-decoration-line-through me-1">@Track.Name</span>
            }

            @if (!string.IsNullOrEmpty(Preview?.Name))
            {
                <span class="small text-info">@Preview.Name</span>
            }
            else if (!string.IsNullOrEmpty(Track.Name))
            {
                <span class="small text-muted fst-italic">(cleared)</span>
            }
        }
        else if (!string.IsNullOrEmpty(Track.Name))
        {
            <span class="text-muted small">@Track.Name</span>
        }

        @* Flag changes - shown as small inline badges *@
        @if (FlagChanges.Count > 0)
        {
            <div class="mt-1">
                @foreach (var change in FlagChanges)
                {
                    <span class="badge @(change.NewValue ? "bg-info" : "bg-secondary") me-1"
                          style="font-size: 0.65rem;">
                        @(change.NewValue ? "+" : "-")@change.Label
                    </span>
                }
            </div>
        }
    </td>
</tr>

@code {
    [Parameter] [EditorRequired] public IMediaTrack Track { get; set; } = default!;
    [Parameter] [EditorRequired] public string? OriginalLanguage { get; set; }
    [Parameter] public TrackPlan? Preview { get; set; }
    [Parameter] public int? MovedFromPosition { get; set; }

    private record FlagChange(string Label, bool NewValue);

    private bool IsReordered => MovedFromPosition.HasValue;

    private string? ResolvedLanguage
    {
        get
        {
            if (Preview?.LanguageCode == null ||
                string.Equals(Preview.LanguageCode, Track.LanguageCode, StringComparison.Ordinal))
            {
                return null;
            }

            return IsoLanguage.Find(Preview.LanguageCode).Name;
        }
    }

    private string DisplayLanguage => ResolvedLanguage ?? Track.LanguageName;

    private bool HasTrackNameChange =>
        Preview?.Name != null && !string.Equals(Track.Name ?? "", Preview.Name, StringComparison.Ordinal);

    private List<FlagChange> FlagChanges
    {
        get
        {
            if (Preview == null)
            {
                return [];
            }

            var changes = new List<FlagChange>();
            if (Preview.IsDefault is { } isDefault && isDefault != Track.IsDefault)
            {
                changes.Add(new FlagChange("Default", isDefault));
            }

            if (Preview.IsForced is { } isForced && isForced != Track.IsForced)
            {
                changes.Add(new FlagChange("Forced", isForced));
            }

            if (Preview.IsHearingImpaired is { } isHi && isHi != Track.IsHearingImpaired)
            {
                changes.Add(new FlagChange("SDH", isHi));
            }

            if (Preview.IsCommentary is { } isComm && isComm != Track.IsCommentary)
            {
                changes.Add(new FlagChange("Commentary", isComm));
            }

            if (Preview.IsVisualImpaired is { } isAd && isAd != Track.IsVisualImpaired)
            {
                changes.Add(new FlagChange("AD", isAd));
            }

            if (Preview.IsDub is { } isDub && isDub != Track.IsDub)
            {
                changes.Add(new FlagChange("Dub", isDub));
            }

            return changes;
        }
    }

}
